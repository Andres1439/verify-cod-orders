{
  "info": {
    "name": "Shopify Orders API - Tests con Datos Correctos",
    "description": "Tests con productos reales de test-andres1.myshopify.com",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://cod-orders.fly.dev",
      "type": "string"
    },
    {
      "key": "shop_domain",
      "value": "test-andres1.myshopify.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "✅ Test 1 - Camiseta (Un Producto)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"shopDomain\": \"test-andres1.myshopify.com\",\n  \"products\": [\n    {\n      \"product_name\": \"camiseta\",\n      \"variant_id\": \"44787808370876\",\n      \"price\": \"20\",\n      \"quantity\": \"1\"\n    }\n  ],\n  \"phone\": \"987654321\",\n  \"first_name\": \"Juan\",\n  \"last_name\": \"Pérez\",\n  \"email\": \"juan.perez@test.com\",\n  \"address1\": \"Av. Lima 123\",\n  \"city\": \"Lima\",\n  \"province\": \"Lima\",\n  \"country\": \"Peru\",\n  \"zip\": \"15001\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/orders",
          "host": ["{{base_url}}"],
          "path": ["api", "orders"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Order created successfully', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData).to.have.property('order');",
              "});",
              "",
              "pm.test('Price calculated correctly', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.debug.price_info.total_order_price).to.equal('20');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
