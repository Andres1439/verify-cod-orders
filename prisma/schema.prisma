// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ENUMS
enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum TicketStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum OrderConfirmationStatus {
  PENDING_CALL
  CONFIRMED
  DECLINED
  NO_ANSWER
  EXPIRED
}

enum OrderSource {
  CHATBOT_STORE
  WHATSAPP
}

enum CallStatus {
  PENDING
  COMPLETED
  NO_ANSWER
  FAILED
}

// MODELS
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model Shop {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_domain           String                 @unique
  access_token          String?
  subscription_plan     SubscriptionPlan?      @default(BASIC)
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt
  
  // Relaciones existentes
  chatbot_configuration ChatbotConfiguration?
  tickets               Ticket[]
  
  // Nuevas relaciones simplificadas
  order_confirmations   OrderConfirmation[]
  telnyx_configuration  TelnyxConfiguration?
  
  // NUEVAS RELACIONES WHATSAPP
  whatsapp_configuration WhatsappBusinessConfig?
}

model ChatbotConfiguration {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id         String   @db.Uuid
  bot_name        String   @default("Verify")
  welcome_message String   @default("Hola! Estoy aquí para ayudarte.")
  webhook_url     String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  shop Shop @relation(fields: [shop_id], references: [id], onDelete: Cascade)

  @@unique([shop_id])
}

model Ticket {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id        String       @db.Uuid
  session_id     String?
  customer_email String
  subject        String
  message        String
  status         TicketStatus @default(PENDING)
  agent_id       String?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt
  assigned_at    DateTime?
  resolved_at    DateTime?
  closed_at      DateTime?

  customerName   String?      // Nombre del cliente
  customerPhone  String?      // Número de teléfono del cliente
  shopDomain     String?      // Dominio de la tienda

  shop Shop @relation(fields: [shop_id], references: [id], onDelete: Cascade)
}

// NUEVAS TABLAS SIMPLIFICADAS

model TelnyxConfiguration {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id       String   @unique @db.Uuid
  api_key       String   // Token de Telnyx
  phone_number  String   // Número para llamadas
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  shop Shop @relation(fields: [shop_id], references: [id], onDelete: Cascade)
}

model OrderConfirmation {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id               String                  @db.Uuid
  
  // Datos básicos del pedido
  internal_order_number String                  // Número interno antes de Shopify
  shopify_order_id      String?                 // Se asigna después de confirmar
  shopify_order_name    String? 
  customer_phone        String
  customer_name         String?
  customer_email        String?
  
  // Datos del pedido
  order_items           Json                    // Items del pedido
  order_total           Decimal                 @db.Decimal(10, 2)
  shipping_address      Json?
  
  // Estado y origen
  source                OrderSource             // CHATBOT_STORE o WHATSAPP
  status                OrderConfirmationStatus @default(PENDING_CALL)
  
  // Fechas importantes
  call_scheduled_at     DateTime?               // Cuándo se programó la llamada
  confirmed_at          DateTime?
  declined_at           DateTime?
  expires_at            DateTime?
  
  created_at            DateTime                @default(now())
  updated_at            DateTime                @updatedAt

  shop Shop @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  call ConfirmationCall?

  @@unique([internal_order_number, shop_id])
  @@index([status])
  @@index([call_scheduled_at])
  @@index([shopify_order_name])  // ✅ AGREGAR SOLO ESTA LÍNEA

}

model ConfirmationCall {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_confirmation_id String     @unique @db.Uuid
  
  // Datos de la llamada
  telnyx_call_id        String?    // ID en Telnyx
  status                CallStatus @default(PENDING)
  customer_response     String?    // "confirmed", "declined", "no_answer"
  
  // Tiempos básicos
  initiated_at          DateTime?
  completed_at          DateTime?
  
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt

  order_confirmation OrderConfirmation @relation(fields: [order_confirmation_id], references: [id], onDelete: Cascade)
}

// NUEVAS TABLAS WHATSAPP

model WhatsappBusinessConfig {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id           String   @unique @db.Uuid

  // Configuración básica
  enabled           Boolean  @default(true)
  welcome_message   String   @default("¡Hola! ¿En qué puedo ayudarte?")
  business_hours    Json?
  auto_responses    Json?

  // Credenciales de Meta Business
  accessToken       String?  @db.Text
  phoneNumberId     String?
  businessAccountId String?
  webhookToken      String?
  businessName      String?
  agentPrompt       String?  @db.Text

  // Estado de verificación
  isVerified        Boolean  @default(false)
  isActive          Boolean  @default(true)
  lastVerified      DateTime?

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  shop              Shop     @relation(fields: [shop_id], references: [id], onDelete: Cascade)
}
