# ============================================================================
# VARIABLES DE ENTORNO PARA VERIFY COD ORDERS
# ============================================================================

# ============================================================================
# SHOPIFY APP CONFIGURATION
# ============================================================================
SHOPIFY_API_KEY=tu_api_key_aqui
SHOPIFY_API_SECRET=tu_api_secret_aqui
SHOPIFY_APP_URL=https://tu-dominio-produccion.com

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://usuario:password@host:puerto/database
DIRECT_URL=postgresql://usuario:password@host:puerto/database

# ============================================================================
# EMAIL SERVICE (RESEND)
# ============================================================================
RESEND_API_KEY=tu_resend_api_key_aqui
MY_TEST_EMAIL=tu-email@ejemplo.com

# ============================================================================
# N8N INTEGRATION
# ============================================================================
N8N_WEBHOOK_URL=https://tu-n8n-instance.com

# ============================================================================
# CHATBOT CONFIGURATION
# ============================================================================
CHATBOT_API_BASE_URL=https://tu-dominio-produccion.com
CHATBOT_API_FALLBACK_URL=http://localhost:3000

# ============================================================================
# ENVIRONMENT
# ============================================================================
NODE_ENV=development

# ============================================================================
# OPTIONAL: CUSTOM SHOP DOMAINS
# ============================================================================
SHOP_CUSTOM_DOMAIN=tu-dominio-personalizado.com

# ============================================================================
# OPTIONAL: TWILIO CONFIGURATION
# ============================================================================
TWILIO_ACCOUNT_SID=tu_twilio_account_sid
TWILIO_AUTH_TOKEN=tu_twilio_auth_token

# ============================================================================
# OPTIONAL: TELNYX CONFIGURATION
# ============================================================================
TELNYX_API_KEY=tu_telnyx_api_key 